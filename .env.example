# Django secret key (required) — generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Debug mode (default: False)
DEBUG=True

# Comma-separated allowed hostnames (default: 127.0.0.1,localhost)
ALLOWED_HOSTS=127.0.0.1,localhost

# Database URL (default: sqlite:///db.sqlite3)
# For PostgreSQL: postgresql://user:password@localhost:5432/ameaozon
DATABASE_URL=sqlite:///db.sqlite3
