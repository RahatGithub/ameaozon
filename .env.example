# Django secret key (required) — generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Debug mode (default: True)
DEBUG=True

# Comma-separated allowed hostnames (default: 127.0.0.1,localhost)
ALLOWED_HOSTS=127.0.0.1,localhost
